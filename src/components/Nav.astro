---
const { currentPath = '' } = Astro.props;
const link = (href) => ({
  href,
  active: currentPath === href || (href !== '/' && currentPath.startsWith(href)),
});

const links = [
  link('/'),
  link('/events'),
  link('/about'),
  link('/contact'),
];

const label = {
  '/': 'Home',
  '/events': 'Events',
  '/about': 'About',
  '/contact': 'Contact',
};
---

<header class="nav">
  <div class="container nav-inner">
    <a class="brand" href="/">
      <strong>networkedlearning.ai</strong>
      <span>Networks × AI × Learning</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} style={l.active ? 'color: var(--text); border-color: var(--border); background: rgba(255,255,255,0.04);' : ''}>
          {label[l.href]}
        </a>
      ))}
    </nav>
  </div>
</header>
